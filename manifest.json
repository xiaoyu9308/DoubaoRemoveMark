{
  "manifest_version": 3,
  "name": "豆包去水印",
  "version": "1.0.0",
  "key": "",
  "description": "豆包AI生图无水印下载，自动替换带水印图片为原始无水印图片",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "downloads",
    "contextMenus",
    "storage",
    "scripting",
    "nativeMessaging"
  ],
  "host_permissions": [
    "https://*.doubao.com/*",
    "https://*.byteimg.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.doubao.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
